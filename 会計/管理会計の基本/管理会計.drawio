        <mxCell id="H9thnC8C52KWSOINJ_J2-9" value="&lt;b&gt;【会計学】&lt;/b&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font style=&quot;font-size: 24px;&quot;&gt;全部原価計算、連結会計、時価会計、減損会計、退職給付会計、...&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=3;fillColor=#f8cecc;strokeColor=#b85450;fontSize=35;align=left;spacingRight=10;spacingLeft=10;" vertex="1" parent="1">
