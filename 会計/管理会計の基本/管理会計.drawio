  <diagram name="財務会計と管理会計のテーマ" id="Upq2zGf7RkK0_gL1ATr_">
    <mxGraphModel dx="2330" dy="1050" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="H9thnC8C52KWSOINJ_J2-1" value="財務&lt;div&gt;会計&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=5;fontSize=45;fontStyle=1;labelPosition=left;verticalLabelPosition=middle;align=right;verticalAlign=middle;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="-5.5" y="10" width="1135.5" height="450" as="geometry" />
        </mxCell>
        <mxCell id="H9thnC8C52KWSOINJ_J2-4" value="&lt;b&gt;⚫︎決算書の理解 ← 【過去の業績】&lt;/b&gt;&lt;div&gt;&lt;font style=&quot;font-size: 24px;&quot;&gt;　①損益計算書PL（期間損益の算定）&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 24px;&quot;&gt;　②貸借対照表BS（財政状態の把握）&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 24px;&quot;&gt;　③キャッシュフロー計算書CS（現金の動き）&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=3;fillColor=#f8cecc;strokeColor=#b85450;fontSize=35;align=left;spacingRight=10;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="19.5" y="30" width="660.5" height="220" as="geometry" />
        </mxCell>
        <mxCell id="H9thnC8C52KWSOINJ_J2-5" value="" style="group" vertex="1" connectable="0" parent="1">
          <mxGeometry x="-5.5" y="570" width="1135.5" height="290" as="geometry" />
        </mxCell>
        <mxCell id="H9thnC8C52KWSOINJ_J2-2" value="管理&lt;div&gt;会計&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=5;fontSize=45;fontStyle=1;labelPosition=left;verticalLabelPosition=middle;align=right;verticalAlign=middle;spacingRight=10;" vertex="1" parent="H9thnC8C52KWSOINJ_J2-5">
          <mxGeometry width="1135.5" height="290" as="geometry" />
        </mxCell>
        <mxCell id="H9thnC8C52KWSOINJ_J2-3" value="&lt;b&gt;⚫︎業績管理と意思決定 ← 【未来志向】&lt;/b&gt;&lt;div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 26px;&quot;&gt;　・変動損益計算書の活用（損益分岐点、付加価値の分配法）&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 26px;&quot;&gt;　・意思決定への活用（価格の設定、投資の採算判断）&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 26px;&quot;&gt;　・利益・資金計画の立て方（中期＜3〜5年＞計画、来季の予算策定）&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 26px;&quot;&gt;　・企業価値の算定（買収価格の決定、株価の算定）&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=3;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=35;align=left;spacingRight=10;spacingLeft=10;" vertex="1" parent="H9thnC8C52KWSOINJ_J2-5">
          <mxGeometry x="29.303225806451614" y="20" width="1074.4516129032259" height="250" as="geometry" />
        </mxCell>
        <mxCell id="H9thnC8C52KWSOINJ_J2-6" value="&lt;b&gt;⚫︎財務分析 ← 【現状分析】&lt;/b&gt;&lt;div&gt;&lt;font style=&quot;font-size: 24px;&quot;&gt;　・収益性（ROA、ROE）、安全性（流動比率、固定比率）&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 24px;&quot;&gt;　・キャッシュフロー分析（営業CF、投資CF、財務CF）&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 24px;&quot;&gt;　・生産性（単位当たりの売上・原価）、成長性（EPS）&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=3;fillColor=#f8cecc;strokeColor=#b85450;fontSize=35;align=left;spacingRight=10;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="19.5" y="270" width="660.5" height="180" as="geometry" />
        </mxCell>
