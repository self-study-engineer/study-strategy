        <mxCell id="j7QiJRd-Z8HoQsGHulCx-16" value="&lt;div&gt;営業利益から営業外損益を足し引きした利益。全ての事業活動常日頃上がってくる&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;利益。&lt;/span&gt;&lt;/div&gt;" style="shape=callout;whiteSpace=wrap;html=1;perimeter=calloutPerimeter;direction=north;size=50;position=0.22;position2=0.25;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=3;fontSize=25;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="70" y="310" width="610" height="90" as="geometry" />
        </mxCell>
        <mxCell id="j7QiJRd-Z8HoQsGHulCx-17" value="&lt;div&gt;経常利益からその年度だけに特別に発生した損益を足し引きした利益。&lt;/div&gt;" style="shape=callout;whiteSpace=wrap;html=1;perimeter=calloutPerimeter;direction=north;size=70;position=0.33;position2=0.25;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=3;fontSize=25;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="180" y="440" width="500" height="90" as="geometry" />
        </mxCell>
        <mxCell id="j7QiJRd-Z8HoQsGHulCx-18" value="&lt;div&gt;税引き前当期純利益から税金を支払った後の利益。「最終利益」「純利益」などとも言われる。&lt;/div&gt;" style="shape=callout;whiteSpace=wrap;html=1;perimeter=calloutPerimeter;direction=north;size=70;position=0.22;position2=0.25;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=3;fontSize=25;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="10" y="540" width="670" height="90" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
